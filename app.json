{
  "expo": {
    "name": "KHEYA - Unlock Your Future",
    "slug": "kheia",
    "scheme": "kheia",
    "version": "0.3.5",
    "orientation": "default",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "userInterfaceStyle": "automatic",
    "plugins": [
      "./node_modules/expo-router/app.plugin.js",
      "expo-asset",
      [
        "expo-audio",
        {
          "microphonePermission": false
        }
      ],
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "KHEYA folosește galeria pentru poza ta de profil din clasament.",
          "cameraPermission": false,
          "microphonePermission": false
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": true,
            "buildArchs": ["armeabi-v7a", "arm64-v8a", "x86", "x86_64"]
          }
        }
      ]
    ],
    "jsEngine": "hermes",
    "icon": "./assets/kheya_icon_1024x1024.png",
    "splash": {
      "image": "./assets/kheya_splash_1080x1920.png",
      "resizeMode": "contain",
      "backgroundColor": "#1e293b"
    },
    "description": "Pregătire Evaluare Națională 2026, Bacalaureat Română, simulări admitere. Teorie, quiz-uri și teste pentru EN și BAC.",
    "android": {
      "versionCode": 13,
      "package": "com.kheia.edumat",
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/kheya_icon_1024x1024.png",
        "backgroundColor": "#1e293b"
      }
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ed20c160-2eb9-4be0-b11e-81050a8300b3"
      }
    },
    "ios": {
      "bundleIdentifier": "com.kheia.edumat",
      "buildNumber": "14",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    }
  }
}
