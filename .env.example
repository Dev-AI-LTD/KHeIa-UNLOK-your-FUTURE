# Supabase (database + edge functions)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
# URL Railway pentru Chat KhEla
EXPO_PUBLIC_NODE_BACKEND_URL=https://your-backend.example.com

# Kinde (autentificare) — https://app.kinde.com
# Callback URLs în Kinde (ambele):
#   kheia://kinde_callback  (build nativ / npm run android)
#   exp://127.0.0.1:8081/--/kinde_callback  (Expo Go + npm run start:usb)
# La start în Expo Go, URL-ul exact apare în Metro log: [Kinde] Expo Go redirect URL
EXPO_PUBLIC_KINDE_DOMAIN=https://your-app.kinde.com
EXPO_PUBLIC_KINDE_CLIENT_ID=your_kinde_client_id

# Supabase (edge functions, server)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_ANON_KEY=your_anon_key
# Pentru kinde-bridge edge function
KINDE_DOMAIN=https://your-app.kinde.com

# AI (node-backend)
OPENAI_API_KEY=sk-proj-xxxx
GEMINI_API_KEY=AIzaSyxxxx
# Voce TTS pentru „Ascultă teoria” (alloy | echo | fable | onyx | nova | shimmer)
TTS_VOICE=nova
# Supabase Edge (tts-speak): supabase secrets set OPENAI_API_KEY=sk-... TTS_VOICE=nova
